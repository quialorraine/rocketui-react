{
  "name": "@rocketui-react/core",
  "version": "0.1.2",
  "type": "module",
  "description": "RocketUI — a production-ready React component library and design system.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/quialorraine/rocketui-react.git"
  },
  "homepage": "https://github.com/quialorraine/rocketui-react#readme",
  "keywords": [
    "react",
    "components",
    "ui",
    "design-system",
    "tailwindcss",
    "headless"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "rocketui": "bin/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist",
    "bin",
    "AGENTS.md",
    "llms.txt",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:lib": "vite build --config vite.lib.config.ts",
    "generate:manifest": "tsx scripts/generate-manifest.ts",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "prepublishOnly": "npm run generate:manifest && npm run build:lib"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "shiki": "^1.29.2",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vite-plugin-dts": "^5.0.3"
  }
}
